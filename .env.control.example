# =============================================================================
# apps/control-plane — env template. Copy to `.env.control` (gitignored) and fill.
#
#   cp .env.control.example .env.control
#
# This is the SOURCE for the control-plane Fly secret sync:
#   apps/control-plane/scripts/sync-fly-secrets.sh   -> app imsg-control-plane
#
# SHARED with the dashboard (duplicated in .env.dashboard — keep in lockstep):
#   DATABASE_URL, DEVICE_TOKEN_PEPPER, WEBHOOK_BASE_URL.
#   *** DEVICE_TOKEN_PEPPER MUST be byte-identical in .env.dashboard ***
#   (the dashboard stores only the peppered hash; a mismatch silently breaks pairing).
# =============================================================================

# --- Database (Neon Postgres) — POOLED (pgbouncer host). Apply db/schema.sql first.
DATABASE_URL=postgres://user:password@host-pooler.neon.tech/dbname?sslmode=require

# --- AgentPhone transport (@imsg/transport) ---------------------------------
AGENTPHONE_API_KEY=
AGENTPHONE_API_BASE=https://api.agentphone.ai
AGENTPHONE_AGENT_ID=
# HMAC secret verifying inbound webhooks. The webhook FAILS CLOSED if unset.
# Generate: openssl rand -hex 32  (set the SAME value in agentphone's config)
AGENTPHONE_WEBHOOK_SECRET=

# --- LLM (assistant) — talks to the LiteLLM proxy ---------------------------
# LiteLLM VIRTUAL KEY (sk-...), minted against the proxy's LITELLM_MASTER_KEY via
# POST /key/generate after imsg-litellm is deployed. Assistant fails closed if unset.
LLM_API_KEY=
# NOTE: LLM_API_BASE is intentionally NOT set here. Prod uses the flycast URL
# baked into apps/control-plane/fly.toml; local dev uses the env.ts default
# (http://localhost:4000/v1). Setting it here would push the wrong base to prod.
LLM_MODEL=gemini-3.5-flash

# --- Control plane ----------------------------------------------------------
# SHARED pepper for pairing/onboarding/device-token hashing. openssl rand -hex 32
# MUST equal DEVICE_TOKEN_PEPPER in .env.dashboard.
DEVICE_TOKEN_PEPPER=
# Public base URL the device + install.sh point at.
WEBHOOK_BASE_URL=https://message.prbe.ai
PORT=8080
