# =============================================================================
# apps/dashboard — env template. Copy to `.env.dashboard` (gitignored) and fill.
#
#   cp .env.dashboard.example .env.dashboard
#
# The dashboard runs on Vercel (no Fly sync script): use this file for local dev,
# and set the same keys in the Vercel project's Environment Variables. NEXT_PUBLIC_*
# are baked in at BUILD time — set them before the first build or links come out blank.
#
# SHARED with the control-plane (duplicated in .env.control — keep in lockstep):
#   DATABASE_URL, DEVICE_TOKEN_PEPPER, WEBHOOK_BASE_URL.
#   *** DEVICE_TOKEN_PEPPER MUST be byte-identical in .env.control ***
# =============================================================================

# --- Database (Neon Postgres) — same POOLED URL as .env.control -------------
DATABASE_URL=postgres://user:password@host-pooler.neon.tech/dbname?sslmode=require
# SHARED pepper — MUST equal DEVICE_TOKEN_PEPPER in .env.control.
DEVICE_TOKEN_PEPPER=
# SHARED HMAC secret for the dashboard's live SSE feed (the browser opens an
# account-scoped EventSource to the control plane, ticket-authed) — MUST equal
# SSE_TICKET_SECRET in .env.control. openssl rand -base64 32.
SSE_TICKET_SECRET=
# Public base URL (shared with control-plane). Local dev: http://localhost:8080;
# prod: your deployed control-plane origin.
WEBHOOK_BASE_URL=http://localhost:8080

# --- Auth (Better Auth, Google SSO only) ------------------------------------
# Google OAuth redirect URI: ${BETTER_AUTH_URL}/api/idp/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Better Auth signing secret (random, long). openssl rand -base64 32
BETTER_AUTH_SECRET=
# Public origin Better Auth runs at (sets cookies + OAuth callback base).
# Local dev: http://localhost:3000. Prod: your dashboard origin.
BETTER_AUTH_URL=http://localhost:3000

# --- Dashboard <-> control plane + public client config ---------------------
# Control-plane base URL the dashboard talks to / builds the install command from.
# Local dev: http://localhost:8080. Prod: the deployed control-plane host
# (e.g. https://imsg-control-plane.fly.dev), NOT the dashboard's own origin.
CONTROL_PLANE_URL=http://localhost:8080
# Public app origin (exposed to the browser; used in links/metadata).
# Local dev: http://localhost:3000. Prod: your dashboard origin.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# NOTE: the agent number is no longer a build-time env var. It now comes from the
# `agent_numbers` pool (per-account, via /api/onboarding/start + the
# /api/account/agent-number endpoint). Seed the pool with scripts/seed-agent-numbers.ts.

# --- Access-request email (Resend) ------------------------------------------
# The invite gate emails an operator when a new user requests access. If
# RESEND_API_KEY is unset, the request is still recorded (accounts.requested_phone)
# but no email is sent — the feature degrades quietly. Get a key at resend.com.
RESEND_API_KEY=
# "From" address. Default onboarding@resend.dev works with no verified domain for
# testing; in prod use a verified sender on your domain (e.g. notify@prbe.ai).
RESEND_FROM=onboarding@resend.dev
# Where new-signup notifications go.
SIGNUP_NOTIFY_EMAIL=richard@prbe.ai
