# =============================================================================
# imessage-coding — environment contract (EVERY variable across all packages)
#
# Copy to `.env` (gitignored) and fill in. Each app reads its own subset; the
# sections below say which app uses what. A few secrets are SHARED and MUST hold
# the SAME value in every app that reads them — those are called out inline.
#
# Quick guide to who reads what:
#   apps/control-plane  : DATABASE_URL, AGENTPHONE_*, LLM_*, DEVICE_TOKEN_PEPPER,
#                         WEBHOOK_BASE_URL, PORT
#   apps/dashboard      : DATABASE_URL, GOOGLE_*, BETTER_AUTH_*, CONTROL_PLANE_URL,
#                         DEVICE_TOKEN_PEPPER, WEBHOOK_BASE_URL, NEXT_PUBLIC_*
#   packages/device     : TOKEN (pairing), IMSG_CONTROL_PLANE_URL (runtime/install)
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Neon Postgres) — control-plane + dashboard (one shared database)
# -----------------------------------------------------------------------------
# Full Neon connection string. Apply db/schema.sql to this database first.
DATABASE_URL=postgres://user:password@host.neon.tech/dbname?sslmode=require

# -----------------------------------------------------------------------------
# AgentPhone transport (@imsg/transport) — control-plane
# The messaging provider that sends/receives the iMessages. *** You create the
# AgentPhone API key + agent and fill these in. ***
# -----------------------------------------------------------------------------
# Secret API key for sending outbound messages (required to send).
AGENTPHONE_API_KEY=
# AgentPhone REST base URL (default shown; override only if instructed).
AGENTPHONE_API_BASE=https://api.agentphone.ai
# The AgentPhone agent id outbound messages are sent as (required to send).
AGENTPHONE_AGENT_ID=
# HMAC secret used to verify inbound webhook signatures. The webhook FAILS CLOSED
# (refuses to verify) if this is unset — set it before accepting inbound messages.
AGENTPHONE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# LLM (orchestrator) — control-plane
# OpenAI-compatible Chat Completions by default, behind a single llmComplete().
# Used only to interpret an inbound reply's INTENT; it can never allow a
# destructive op (that gate is deterministic, in code).
# -----------------------------------------------------------------------------
# API key for the chat-completions endpoint (orchestrator fails closed if unset).
LLM_API_KEY=
# Chat-completions base URL (OpenAI-compatible). Point at your LiteLLM proxy,
# e.g. https://litellm.prbe.ai/v1 — must be reachable from the control-plane host
# (the in-cluster litellm.*.svc URL is NOT reachable from Fly). LLM_API_KEY is then
# a LiteLLM virtual key.
LLM_API_BASE=https://api.openai.com/v1
# Model id as registered in LiteLLM, for the orchestrator's intent classification.
# NOTE: gemini-3.5-flash defaults thinking ON — set thinkingBudget=0 on this model
# in your LiteLLM config so the structured routing call stays fast/cheap/JSON-clean.
LLM_MODEL=gemini-3.5-flash

# -----------------------------------------------------------------------------
# Control plane (apps/control-plane)
# -----------------------------------------------------------------------------
# SHARED SECRET — pepper mixed into pairing/onboarding/device-token hashing.
# MUST be identical in the control-plane AND the dashboard: the dashboard stores
# only the peppered hash, and the control plane re-derives the same hash from the
# raw token to look it up. A mismatch silently breaks pairing. Use a long random
# value, e.g. `openssl rand -hex 32`.
DEVICE_TOKEN_PEPPER=
# Public base URL the device + install.sh point at (e.g. https://message.prbe.ai).
# Also used by the dashboard to build the install one-liner.
WEBHOOK_BASE_URL=https://message.prbe.ai
# Port the control-plane HTTP server binds (default 8080).
PORT=8080

# -----------------------------------------------------------------------------
# Dashboard auth (apps/dashboard — Next.js + Better Auth, Google SSO only)
# -----------------------------------------------------------------------------
# Google OAuth client (your GCP project). Redirect URI:
#   ${BETTER_AUTH_URL}/api/idp/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Better Auth signing secret (random, long). e.g. `openssl rand -base64 32`.
BETTER_AUTH_SECRET=
# Public origin Better Auth runs at (sets cookies + OAuth callback base).
BETTER_AUTH_URL=https://message.prbe.ai

# -----------------------------------------------------------------------------
# Dashboard <-> control plane + public client config (apps/dashboard)
# -----------------------------------------------------------------------------
# Control-plane base URL the dashboard talks to / builds the install command from.
CONTROL_PLANE_URL=http://localhost:8080
# DEVICE_TOKEN_PEPPER (above) is ALSO required by the dashboard — same value.
# Public app origin (exposed to the browser; used in links/metadata).
NEXT_PUBLIC_APP_URL=https://message.prbe.ai
# E.164 phone number users text to reach the agent. Shown in onboarding/home
# deep-links. Public (NEXT_PUBLIC_*), baked in at build time.
NEXT_PUBLIC_AGENT_PHONE_NUMBER=

# -----------------------------------------------------------------------------
# Device plugin (@imsg/device) — local install-time / runtime only
# These are NOT set in the server .env; they're consumed on the developer's
# machine (by install.sh and the plugin), shown here for completeness.
# -----------------------------------------------------------------------------
# Single-use pairing token from the dashboard's Integrations page; install.sh
# embeds it (`curl ... | TOKEN=... sh`) and exchanges it for a device_token.
TOKEN=
# Control-plane base URL the device talks to (defaults to https://message.prbe.ai).
IMSG_CONTROL_PLANE_URL=https://message.prbe.ai
# Optional: override the device state dir (default ~/.claude/plugins/imsg-device).
# IMSG_DEVICE_DIR=
# Optional: force a device_token instead of keychain/file (testing/headless).
# IMSG_DEVICE_TOKEN=
