# =============================================================================
# apps/litellm — env template. Copy to `.env.litellm` (gitignored) and fill.
#
#   cp .env.litellm.example .env.litellm
#
# This is the SOURCE for the LiteLLM proxy Fly secret sync:
#   apps/litellm/scripts/sync-fly-secrets.sh   -> app imsg-litellm
#
# .env-key -> fly-secret-name MAPPING: LITELLM_DATABASE_URL is pushed under the
# name DATABASE_URL. The proxy's litellm-database image runs Prisma migrate on a
# DIRECT connection, so it needs the UNPOOLED Neon URL (host WITHOUT -pooler) —
# kept under a distinct key so it never collides with the pooled DATABASE_URL the
# control-plane/dashboard use.
# =============================================================================

# Admin key that mints virtual keys (LiteLLM general_settings.master_key). sk-...
# Generate: printf 'sk-%s\n' "$(openssl rand -hex 24)"
LITELLM_MASTER_KEY=
# Encrypts stored creds. SET ONCE — never rotate (rotating orphans stored data). sk-...
LITELLM_SALT_KEY=
# UNPOOLED/direct Neon URL (host WITHOUT the -pooler suffix). Pushed as DATABASE_URL.
LITELLM_DATABASE_URL=postgres://user:password@host.neon.tech/dbname?sslmode=require
# Google AI Studio key backing the gemini-3.5-flash model.
GEMINI_API_KEY=
# Cerebras Inference key backing the gpt-oss-120b model (the low-latency option).
# OPTIONAL — leave blank to run Gemini-only; the sync skips it when unset. Set it
# (free tier at https://cloud.cerebras.ai) only to flip LLM_MODEL=gpt-oss-120b.
CEREBRAS_API_KEY=
