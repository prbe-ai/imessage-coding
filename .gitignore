# dependencies — match dirs AND symlinks named node_modules, at any depth
# (a bare `node_modules/` only matches directories, so a stray symlink slips through)
node_modules
**/node_modules

# env — per-app secret files are gitignored; only the *.example templates are tracked.
.env
.env.local
.env.*.local
.env.control
.env.dashboard
.env.litellm

# next.js
.next/
out/

# build output
dist/
build/
*.tsbuildinfo

# logs
*.log
logs/
npm-debug.log*
bun-debug.log*

# os / editor
.DS_Store
.idea/
.vscode/

# misc
coverage/
.turbo/
